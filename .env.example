# ELAM Dashboard Environment Variables
# Copy this file to .env and fill in your actual values

# Google Sheets Configuration
# Get your Sheet ID from the URL: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
VITE_GOOGLE_SHEET_ID=your_google_sheet_id_here

# For Python scripts (use same value as VITE_GOOGLE_SHEET_ID)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Data Update Interval (in milliseconds)
# Default: 120000 (2 minutes)
VITE_UPDATE_INTERVAL=120000

# Application Settings
VITE_APP_TITLE=ELAM Dashboard
VITE_FLEET_NAME=ELAM Logistics

# Optional: API endpoints (for future use)
# VITE_API_BASE_URL=https://your-api.com
