    {
      "parameters": {
        "jsCode": "// Process route start detection\nconst routerData = $('Route Tracking Router').item.json;\nconst routeData = $input.item.json;\n\n// Check if we found a matching route\nif (!routeData.ruta_id) {\n  // No route found, skip\n  return null;\n}\n\n// Route found! Use the ACTUAL unit that triggered the event (not the one in rutas_programadas)\n// Note: Duplicate checking is now handled by subsequent nodes\nconst now = new Date();\nconst fechaInicio = now.toLocaleDateString('es-MX', { day: '2-digit', month: '2-digit', year: 'numeric' });\n\nreturn {\n  unidad: routerData.unidad,  // IMPORTANT: Use actual unit from event, not from rutas_programadas\n  ruta_id: routeData.ruta_id,\n  origen: routeData.origen,\n  destino: routeData.destino,\n  operador: routerData.operador,\n  fecha_inicio: fechaInicio,\n  timestamp_inicio: now.toISOString().replace('T', ' ').substring(0, 19),\n  geocercas_ruta: routeData.geocercas_ruta || ''\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2128, -200],
      "id": "process-route-start",
      "name": "Process Route Start"
