    },
    {
      "parameters": {
        "jsCode": "// Process route completion detection\nconst routerData = $('Route Tracking Router').item.json;\nconst activeRoute = $input.item.json;\n\n// Check if unit has an active route\nif (!activeRoute.ruta_id) {\n  // No active route, skip\n  return null;\n}\n\n// Check if current geocerca matches the destination\nif (routerData.geocerca !== activeRoute.destino) {\n  // Not at destination yet, skip\n  return null;\n}\n\n// ROUTE COMPLETED!\nconst now = new Date();\nconst startTime = new Date(activeRoute.timestamp_inicio);\nconst durationHours = ((now - startTime) / (1000 * 60 * 60)).toFixed(2);\n\n// Get ISO week number\nconst getWeekNumber = (date) => {\n  const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));\n  const dayNum = d.getUTCDay() || 7;\n  d.setUTCDate(d.getUTCDate() + 4 - dayNum);\n  const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));\n  return Math.ceil((((d - yearStart) / 86400000) + 1) / 7);\n};\n\nreturn {\n  // For rutas_completadas_log\n  timestamp: now.toISOString().replace('T', ' ').substring(0, 19),\n  unidad: activeRoute.unidad,\n  ruta_id: activeRoute.ruta_id,\n  origen: activeRoute.origen,\n  destino: activeRoute.destino,\n  operador: activeRoute.operador,\n  duracion_horas: parseFloat(durationHours),\n  semana_iso: getWeekNumber(now),\n  mes: now.getMonth() + 1,\n  año: now.getFullYear(),\n  notas: 'Ruta completada exitosamente',\n  \n  // For cleanup\n  row_number: activeRoute.row_number\n};"
      },
