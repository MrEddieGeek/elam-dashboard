    {
      "parameters": {
        "jsCode": "// Obtener datos del parser, geocerca y operador\nconst evento = $('Parser Wialon').item.json;\nconst geocerca = $('Buscar Geocerca').item.json;\nconst operador = $('Buscar Operador').item.json;\nconst statusActual = $('Leer Status Actual').item.json;\n\n// Determinar nuevo status y actividad según el tipo de geocerca y acción\nlet nuevoStatus = '';\nlet nuevaActividad = '';\n\n// Si encontramos la geocerca en nuestra base de datos\nif (geocerca && geocerca.nombre) {\n  // Usar el status y actividad predefinidos según entrada/salida\n  if (evento.accion === 'entrada') {\n    nuevoStatus = geocerca.status_entrada || 'En Ruta';\n    nuevaActividad = geocerca.actividad_entrada || 'Verificar';\n  } else if (evento.accion === 'salida') {\n    nuevoStatus = geocerca.status_salida || 'En Ruta';\n    nuevaActividad = geocerca.actividad_salida || 'Tránsito';\n  } else {\n    // Es una alerta\n    nuevoStatus = 'Alerta';\n    nuevaActividad = evento.tipo_evento.replace(/_/g, ' ');\n  }\n} else {\n  // Geocerca no encontrada en la base de datos - usar defaults\n  if (evento.accion === 'entrada') {\n    nuevoStatus = 'En Ruta';\n    nuevaActividad = 'Verificar ubicación';\n  } else if (evento.accion === 'salida') {\n    nuevoStatus = 'En Ruta';\n    nuevaActividad = 'Tránsito';\n  } else {\n    nuevoStatus = 'Alerta';\n    nuevaActividad = evento.tipo_evento.replace(/_/g, ' ');\n  }\n}\n\n// *** NUEVA FUNCIONALIDAD: Calcular Próximo Movimiento ***\nlet proximoMovimiento = '';\nswitch(nuevoStatus) {\n  case 'Pensión':\n  case 'Pensíon':\n    proximoMovimiento = 'Disponible para asignación';\n    break;\n  case 'Taller':\n    proximoMovimiento = 'En reparación';\n    break;\n  case 'Descargando':\n    proximoMovimiento = 'Regreso a base';\n    break;\n  case 'En Puerto':\n    proximoMovimiento = 'Esperando carga';\n    break;\n  case 'Disponible':\n    proximoMovimiento = 'Pendiente de asignación';\n    break;\n  case 'En Ruta':\n    proximoMovimiento = 'En tránsito';\n    break;\n  case 'Caseta':\n    proximoMovimiento = 'En tránsito';\n    break;\n  default:\n    proximoMovimiento = 'Verificar status';\n}\n\n// Retornar objeto con toda la información necesaria\nreturn {\n  unidad: evento.unidad,\n  nuevo_status: nuevoStatus,\n  nueva_actividad: nuevaActividad,\n  proximo_movimiento: proximoMovimiento,\n  operador: operador.operador_asignado || 'Sin asignar',\n  status_anterior: statusActual.Status || 'Desconocido',\n  ubicacion: geocerca.nombre || evento.geocerca,\n  tipo_geocerca: geocerca.tipo || 'desconocido',\n  evento_original: evento,\n  geocerca_data: geocerca,\n  timestamp: new Date().toISOString()\n};"
      },
