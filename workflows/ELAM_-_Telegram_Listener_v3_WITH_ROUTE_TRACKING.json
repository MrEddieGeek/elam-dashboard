    {
      "parameters": {
        "jsCode": "// *** ROUTE TRACKING LOGIC ***\n// This node determines if we need to check for route start or route completion\n\nconst evento = $('Parser Wialon').item.json;\nconst statusData = $('Determinar Nuevo Status').item.json;\n\n// Only process entrada (entry) events for route tracking\nif (evento.accion !== 'entrada') {\n  return { skipRouteTracking: true };\n}\n\nreturn {\n  unidad: evento.unidad,\n  geocerca: statusData.ubicacion,\n  operador: statusData.operador,\n  timestamp: new Date().toISOString(),\n  lat: evento.lat,\n  lng: evento.lng,\n  checkRouteStart: true,\n  checkRouteCompletion: true\n};"
      },
