            "rutas_semana": "0"
          },
          "matchingColumns": ["Unidad"]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [800, 0],
      "id": "reset-counters",
      "name": "Reset All Counters to 0",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "4Yv3IPJWrDIRUALZ",
          "name": "ELAM_Google_Sheets"
        }
      }
    },
    {
