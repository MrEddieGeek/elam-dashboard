      "typeVersion": 1.2,
      "position": [0, 0],
      "id": "schedule-trigger",
      "name": "Every Monday 00:00",
      "notes": "Triggers every Monday at midnight (Mexico City timezone)"
    },
    {
      "parameters": {
        "jsCode": "// Log the reset operation start\nconst now = new Date();\nconst weekNumber = Math.ceil((((now - new Date(now.getFullYear(), 0, 1)) / 86400000) + 1) / 7);\n\nreturn {\n  timestamp: now.toISOString().replace('T', ' ').substring(0, 19),\n  week_number: weekNumber,\n  year: now.getFullYear(),\n  action: 'weekly_counter_reset',\n  message: `Resetting weekly route counters for week ${weekNumber}, ${now.getFullYear()}`\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [200, 0],
      "id": "prepare-reset",
      "name": "Prepare Reset Data"
    },
    {
      "parameters": {
        "documentId": {
          "__rl": true,
          "value": "1KKTGm1dw3oPiEZJfp3Ydiz01ElMonrkWa7zMkLc_NHE",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "status_operativo",
          "mode": "name"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [400, 0],
      "id": "get-all-units",
      "name": "Get All Units",
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "4Yv3IPJWrDIRUALZ",
          "name": "ELAM_Google_Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Prepare batch update for all units\n// Set rutas_semana to 0 for each unit\n\nconst units = $input.all();\nconst updates = [];\n\nfor (const unit of units) {\n  updates.push({\n    unidad: unit.json.Unidad,\n    rutas_semana: 0,\n    old_count: unit.json.rutas_semana || 0\n  });\n}\n\nreturn updates;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [600, 0],
      "id": "prepare-updates",
      "name": "Prepare Counter Reset"
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "1KKTGm1dw3oPiEZJfp3Ydiz01ElMonrkWa7zMkLc_NHE",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "status_operativo",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
