        "googleSheetsOAuth2Api": {
          "id": "4Yv3IPJWrDIRUALZ",
          "name": "ELAM_Google_Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Final summary\nconst resetData = $('Prepare Reset Data').item.json;\nconst unitsUpdated = $('Prepare Counter Reset').all().length;\n\nreturn {\n  success: true,\n  timestamp: resetData.timestamp,\n  week_number: resetData.week_number,\n  year: resetData.year,\n  units_updated: unitsUpdated,\n  message: `Successfully reset ${unitsUpdated} unit counters for week ${resetData.week_number}/${resetData.year}`\n};"
      },
      "type": "n8n-nodes-base.code",
