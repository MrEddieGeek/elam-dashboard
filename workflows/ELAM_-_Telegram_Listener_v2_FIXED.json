    {
      "parameters": {
        "jsCode": "// Obtener datos del parser y de la geocerca\nconst evento = $('Parser Wialon').item.json;\nconst geocerca = $json;\n\n// Determinar nuevo status y actividad según el tipo de geocerca y acción\nlet nuevoStatus = '';\nlet nuevaActividad = '';\n\n// Si encontramos la geocerca en nuestra base de datos\nif (geocerca && geocerca.nombre) {\n  // Usar el status y actividad predefinidos según entrada/salida\n  if (evento.accion === 'entrada') {\n    nuevoStatus = geocerca.status_entrada || 'En Ruta';\n    nuevaActividad = geocerca.actividad_entrada || 'Verificar';\n  } else if (evento.accion === 'salida') {\n    nuevoStatus = geocerca.status_salida || 'En Ruta';\n    nuevaActividad = geocerca.actividad_salida || 'Tránsito';\n  } else {\n    // Es una alerta\n    nuevoStatus = 'Alerta';\n    nuevaActividad = evento.tipo_evento.replace(/_/g, ' ');\n  }\n} else {\n  // Geocerca no encontrada en la base de datos - usar defaults\n  if (evento.accion === 'entrada') {\n    nuevoStatus = 'En Ruta';\n    nuevaActividad = 'Verificar ubicación';\n  } else if (evento.accion === 'salida') {\n    nuevoStatus = 'En Ruta';\n    nuevaActividad = 'Tránsito';\n  } else {\n    nuevoStatus = 'Alerta';\n    nuevaActividad = evento.tipo_evento.replace(/_/g, ' ');\n  }\n}\n\n// Retornar objeto con toda la información necesaria\nreturn {\n  unidad: evento.unidad,\n  nuevo_status: nuevoStatus,\n  nueva_actividad: nuevaActividad,\n  ubicacion: geocerca.nombre || evento.geocerca,\n  tipo_geocerca: geocerca.tipo || 'desconocido',\n  evento_original: evento,\n  geocerca_data: geocerca,\n  timestamp: new Date().toISOString()\n};"
      },
