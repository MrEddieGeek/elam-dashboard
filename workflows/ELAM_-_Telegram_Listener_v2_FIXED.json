{
  "name": "ELAM - Telegram Listener v2",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// Obtener datos directamente del webhook\n// Los datos ya vienen como JSON desde Wialon\nconst data = $input.item.json;\n\n// Debug: ver qué recibimos\nconsole.log('Datos recibidos:', JSON.stringify(data, null, 2));\n\n// Validar que tengamos los datos esperados de Wialon\nif (!data.unidad || !data.evento) {\n  // Si no están directamente, pueden estar en 'body'\n  if (data.body) {\n    const bodyData = typeof data.body === 'string' ? JSON.parse(data.body) : data.body;\n    \n    return [{\n      tipo_evento: bodyData.evento,\n      unidad: bodyData.unidad,\n      geocerca: bodyData.geocerca || '',\n      hora: bodyData.hora || new Date().toISOString(),\n      velocidad: bodyData.velocidad || '0',\n      lat: bodyData.lat || '',\n      lng: bodyData.lng || '',\n      ubicacion: bodyData.ubicacion || bodyData.geocerca || '',\n      accion: bodyData.evento?.includes('entrada') ? 'entrada' : bodyData.evento?.includes('salida') ? 'salida' : 'alerta',\n      timestamp: new Date().toISOString()\n    }];\n  }\n  \n  throw new Error('No se encontraron datos de Wialon. Keys recibidos: ' + Object.keys(data).join(', '));\n}\n\n// Si los datos están directamente disponibles\nreturn [{\n  tipo_evento: data.evento,\n  unidad: data.unidad,\n  geocerca: data.geocerca || '',\n  hora: data.hora || new Date().toISOString(),\n  velocidad: data.velocidad || '0',\n  lat: data.lat || '',\n  lng: data.lng || '',\n  ubicacion: data.ubicacion || data.geocerca || '',\n  accion: data.evento?.includes('entrada') ? 'entrada' : data.evento?.includes('salida') ? 'salida' : 'alerta',\n  timestamp: new Date().toISOString()\n}];"
      },
      "type": "n8n-nodes-base.code",
